<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>For Ahona 💖</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Georgia', serif;
        }

        body {
            background: radial-gradient(circle, #1a0011, #000000);
            color: #fff;
            overflow-x: hidden;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            perspective: 1000px;
        }

        /* Twinkling Stars Background */
        .stars {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        /* Card Container with Fade-in */
        .letter-container {
            width: 90%;
            max-width: 600px;
            background: rgba(255, 192, 203, 0.05);
            border: 1px solid rgba(255, 182, 193, 0.2);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 40px 30px;
            text-align: center;
            box-shadow: 0 0 30px rgba(255, 105, 180, 0.2);
            z-index: 10;
            opacity: 0;
            transform: translateY(30px);
            animation: fadeIn 2s ease-out forwards;
        }

        @keyframes fadeIn {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Glowing Rose Gold Text */
        h1 {
            font-size: 2.5rem;
            color: #ffb6c1;
            text-shadow: 0 0 15px rgba(255, 182, 193, 0.8), 0 0 25px rgba(255, 105, 180, 0.5);
            margin-bottom: 30px;
        }

        .letter-content {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #ffe4e1;
            text-align: justify;
            margin-bottom: 40px;
            text-shadow: 0 0 5px rgba(255, 255, 255, 0.2);
        }

        .letter-content p {
            margin-bottom: 20px;
        }

        .proposal-text {
            font-size: 1.4rem;
            font-weight: bold;
            color: #ff69b4;
            margin-top: 30px;
            text-shadow: 0 0 10px rgba(255, 105, 180, 0.8);
        }

        /* Buttons Layout */
        .btn-container {
            position: relative;
            display: flex;
            justify-content: center;
            gap: 20px;
            height: 60px;
            margin-top: 30px;
        }

        .btn {
            padding: 12px 30px;
            font-size: 1rem;
            font-weight: bold;
            border: none;
            border-radius: 25px;
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 20;
        }

        #yesBtn {
            background: linear-gradient(45deg, #ff69b4, #ffb6c1);
            color: white;
            box-shadow: 0 0 15px rgba(255, 105, 180, 0.6);
        }

        #yesBtn:hover {
            transform: scale(1.1);
            box-shadow: 0 0 25px rgba(255, 105, 180, 0.9);
        }

        #noBtn {
            background: rgba(255, 255, 255, 0.1);
            color: #ffe4e1;
            border: 1px solid rgba(255, 182, 193, 0.3);
            position: absolute;
        }

        /* Petals & Hearts Particle System */
        .particle {
            position: fixed;
            pointer-events: none;
            z-index: 5;
            animation: fall linear forwards;
        }

        @keyframes fall {
            0% {
                transform: translateY(-10vh) rotate(0deg);
                opacity: 1;
            }
            100% {
                transform: translateY(110vh) rotate(360deg);
                opacity: 0;
            }
        }

        /* Success Message Overlay */
        .success-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.9);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 100;
            opacity: 0;
            pointer-events: none;
            transition: opacity 1s ease;
        }

        .success-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .success-overlay h2 {
            font-size: 3rem;
            color: #ff69b4;
            text-shadow: 0 0 20px rgba(255, 105, 180, 1);
            margin-bottom: 20px;
            text-align: center;
            padding: 0 20px;
        }
    </style>
</head>
<body>

    <div class="stars" id="starsContainer"></div>
    <div class="particles-container" id="particlesContainer"></div>

    <div class="letter-container">
        <h1>Dearest Ahona, ✨</h1>
        
        <div class="letter-content">
            <p>From the moment you walked into my life, everything changed. You brought a light with you that chased away every bit of darkness, and your smile became my absolute favorite sight in the world.</p>
            
            <p>Every single day, I find myself falling a little deeper in love with you. It’s in the quiet moments, the laughter we share, and the way just thinking of you makes my heart skip a beat. You are my confidante, my happiest thought, and the person I want to share every sunset with.</p>
            
            <p>I don't just want a fleeting moment with you; I want a lifetime of them. I want to be there for your brightest days and hold your hand through the stormy ones.</p>
            
            <p class="proposal-text">Ahona, will you marry me and make me the happiest person alive? 💍</p>
        </div>

        <div class="btn-container">
            <button class="btn" id="yesBtn">Yes, forever! 💕</button>
            <button class="btn" id="noBtn" style="left: 60%;">Maybe later…</button>
        </div>
    </div>

    <!-- Celebration Screen -->
    <div class="success-overlay" id="successOverlay">
        <h2>I knew you'd say Yes! 💖🌹💍</h2>
        <p style="font-size: 1.5rem; color: #ffe4e1;">Forever and always, just you and me. ✨</p>
    </div>

    <script>
        // 1. Create Twinkling Stars
        const starsContainer = document.getElementById('starsContainer');
        for (let i = 0; i < 100; i++) {
            const star = document.createElement('div');
            star.style.position = 'absolute';
            star.style.width = Math.random() * 3 + 'px';
            star.style.height = star.style.width;
            star.style.background = '#fff';
            star.style.top = Math.random() * 100 + 'vh';
            star.style.left = Math.random() * 100 + 'vw';
            star.style.borderRadius = '50%';
            star.style.opacity = Math.random();
            star.style.animation = `twinkle ${Math.random() * 3 + 2}s infinite alternate`;
            starsContainer.appendChild(star);
        }

        // Add CSS twinkle keyframe dynamically
        const style = document.createElement('style');
        style.innerHTML = `@keyframes twinkle { from { opacity: 0.2; } to { opacity: 1; } }`;
        document.head.appendChild(style);

        // 2. Falling Petals & Hearts
        const particlesContainer = document.getElementById('particlesContainer');
        const emojis = ['🌸', '🌹', '💗', '✨', '❤️'];

        function createParticle() {
            const particle = document.createElement('div');
            particle.className = 'particle';
            particle.innerText = emojis[Math.floor(Math.random() * emojis.length)];
            particle.style.left = Math.random() * 100 + 'vw';
            particle.style.fontSize = Math.random() * 20 + 15 + 'px';
            particle.style.animationDuration = Math.random() * 3 + 4 + 's';
            particlesContainer.appendChild(particle);

            setTimeout(() => {
                particle.remove();
            }, 7000);
        }
        setInterval(createParticle, 300);

        // 3. Running Away Button Logic
        const noBtn = document.getElementById('noBtn');
        const yesBtn = document.getElementById('yesBtn');
        let clickCount = 0;

        noBtn.addEventListener('mouseover', moveButton);
        noBtn.addEventListener('click', moveButton);

        function moveButton() {
            clickCount++;
            
            if (clickCount >= 5) {
                // After 5 attempts, auto triggers YES
                triggerSuccess();
                return;
            }

            // Calculate random position inside the container boundaries safely
            const container = document.querySelector('.btn-container');
            const maxWidth = container.clientWidth - noBtn.clientWidth;
            const maxHeight = 300; // Allow it to jump vertically too
            
            const randomX = Math.floor(Math.random() * maxWidth);
            const randomY = Math.floor((Math.random() - 0.5) * maxHeight);

            noBtn.style.left = randomX + 'px';
            noBtn.style.transform = `translateY(${randomY}px)`;
        }

        // 4. Success Interaction
        yesBtn.addEventListener('click', triggerSuccess);

        function triggerSuccess() {
            const overlay = document.getElementById('successOverlay');
            overlay.classList.add('active');

            // Burst lots of emojis
            for (let i = 0; i < 150; i++) {
                setTimeout(() => {
                    const burst = document.createElement('div');
                    burst.className = 'particle';
                    burst.innerText = ['💍', '💖', '🌹', '🎉', '🥂', '👩‍❤️‍👨'][Math.floor(Math.random() * 6)];
                    burst.style.left = Math.random() * 100 + 'vw';
                    burst.style.fontSize = Math.random() * 30 + 20 + 'px';
                    burst.style.animationDuration = Math.random() * 2 + 2 + 's';
                    document.body.appendChild(burst);
                }, i * 20);
            }
        }
    </script>
</body>
</html>
